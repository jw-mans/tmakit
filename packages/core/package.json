{
  "name": "@tmakit/core",
  "version": "0.0.0",
  "type": "module",
  "description": "Shared foundation for tmakit: SDK-agnostic bridge protocol types, event map and transport adapters",
  "license": "MIT",
  "keywords": ["telegram", "telegram-mini-apps", "tma", "mock", "bridge", "webapp"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jw-mans/tmakit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/jw-mans/tmakit/tree/main/packages/core#readme",
  "bugs": "https://github.com/jw-mans/tmakit/issues",
  "sideEffects": false,
  "publishConfig": { "access": "public" },
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@telegram-apps/bridge": "*",
    "@tma.js/bridge": "*"
  },
  "peerDependenciesMeta": {
    "@telegram-apps/bridge": { "optional": true },
    "@tma.js/bridge": { "optional": true }
  }
}
