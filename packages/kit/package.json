{
  "name": "tma-kit",
  "version": "0.0.0",
  "type": "module",
  "description": "Opinionated runtime helpers for Telegram Mini Apps: auth, viewport/safe-area, storage, payments, navigation",
  "license": "MIT",
  "keywords": ["telegram", "telegram-mini-apps", "tma", "react", "hooks", "initdata", "cloudstorage", "viewport", "payments", "webapp"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jw-mans/tmakit.git",
    "directory": "packages/kit"
  },
  "homepage": "https://github.com/jw-mans/tmakit/tree/main/packages/kit#readme",
  "bugs": "https://github.com/jw-mans/tmakit/issues",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tmakit/core": "*"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
