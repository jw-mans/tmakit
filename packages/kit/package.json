{
  "name": "tma-kit",
  "version": "0.0.0",
  "type": "module",
  "description": "Opinionated runtime helpers for Telegram Mini Apps: auth, viewport/safe-area, storage, payments, navigation",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tmakit/core": "*"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
