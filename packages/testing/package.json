{
  "name": "@tmakit/testing",
  "version": "0.0.0",
  "type": "module",
  "description": "Dev-only test utilities for tmakit: unit-test bridge double and Playwright driver on the core mock engine",
  "license": "MIT",
  "keywords": ["telegram", "telegram-mini-apps", "tma", "testing", "playwright", "vitest", "mock"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jw-mans/tmakit.git",
    "directory": "packages/testing"
  },
  "homepage": "https://github.com/jw-mans/tmakit/tree/main/packages/testing#readme",
  "bugs": "https://github.com/jw-mans/tmakit/issues",
  "sideEffects": false,
  "publishConfig": { "access": "public" },
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tmakit/core": "*"
  },
  "peerDependencies": {
    "tma-kit": "*"
  }
}
