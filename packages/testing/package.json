{
  "name": "@tmakit/testing",
  "version": "0.0.0",
  "type": "module",
  "description": "Dev-only test utilities for tmakit: unit-test bridge double and Playwright driver on the core mock engine",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tmakit/core": "*"
  },
  "peerDependencies": {
    "tma-kit": "*"
  }
}
